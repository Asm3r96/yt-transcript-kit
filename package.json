{
  "name": "yt-transcript-kit",
  "version": "0.2.0",
  "description": "Fetch YouTube transcripts and caption text with a lightweight TypeScript API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "yt-transcript-kit": "dist/cli.js"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "smoke": "tsx scripts/smoke.ts",
    "release:check": "npm run typecheck && npm run test && npm run build",
    "preversion": "npm run release:check",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "youtube",
    "transcript",
    "captions",
    "subtitles",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Asm3r96/yt-transcript-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Asm3r96/yt-transcript-kit/issues"
  },
  "homepage": "https://github.com/Asm3r96/yt-transcript-kit#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
